{
  "datasets": [
    {
      "name": "8d548eef",
      "displayName": "Average Delay Days",
      "queryLines": [
        "SELECT \n",
        "DATE_FORMAT(order_date, 'yyyy-MM') AS order_month,\n",
        "ROUND(AVG(delay_days),2) AS avg_delay_days\n",
        "FROM supply_chain.silver.car_orders_clean\n",
        "GROUP BY DATE_FORMAT(order_date, 'yyyy-MM')\n",
        "ORDER BY order_month;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "57775b30",
      "displayName": "On-Time Delivery Rate",
      "queryLines": [
        "SELECT \n",
        "CASE \n",
        "WHEN is_late_delivery = false THEN 'On Time'\n",
        "ELSE 'Late'\n",
        "END AS delivery_status,\n",
        "COUNT(*) AS order_count\n",
        "FROM supply_chain.silver.car_orders_clean\n",
        "GROUP BY delivery_status;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "c4520973",
      "displayName": "Transport Mode Risk Analysis",
      "queryLines": [
        "SELECT \n",
        "transport_mode,\n",
        "ROUND(AVG(delay_days),2) AS avg_delay_risk\n",
        "FROM supply_chain.silver.car_orders_clean\n",
        "GROUP BY transport_mode\n",
        "ORDER BY avg_delay_risk DESC;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "8f24038e",
      "displayName": "Rating Distribution",
      "queryLines": [
        "SELECT \n",
        "rating,\n",
        "COUNT(order_key) AS customer_count\n",
        "FROM supply_chain.silver.car_orders_clean\n",
        "GROUP BY rating\n",
        "ORDER BY rating;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "12cc3949",
      "displayName": "Delivery Duration vs Rating Correlation",
      "queryLines": [
        "SELECT \n",
        "delivery_duration_days,\n",
        "AVG(rating) AS avg_rating\n",
        "FROM supply_chain.silver.car_orders_clean\n",
        "GROUP BY delivery_duration_days\n",
        "ORDER BY delivery_duration_days;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "be140979",
      "displayName": "Country Logistics Performance",
      "queryLines": [
        "SELECT \n",
        "country,\n",
        "ROUND(AVG(delay_days),2) AS avg_delay,\n",
        "COUNT(order_key) AS order_volume\n",
        "FROM supply_chain.silver.car_orders_clean\n",
        "GROUP BY country\n",
        "ORDER BY avg_delay DESC;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "a122fe8c",
      "displayName": "Vehicle Brand Performance",
      "queryLines": [
        "SELECT \n",
        "vehicle_brand,\n",
        "ROUND(AVG(delay_days),2) AS avg_delay,\n",
        "ROUND(AVG(rating),2) AS avg_rating,\n",
        "COUNT(order_key) AS shipment_count\n",
        "FROM supply_chain.silver.car_orders_clean\n",
        "GROUP BY vehicle_brand\n",
        "ORDER BY shipment_count DESC;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "b06f977b",
      "displayName": "Shipment Volume Trend",
      "queryLines": [
        "SELECT \n",
        "DATE_FORMAT(order_date, 'yyyy-MM') AS order_month,\n",
        "COUNT(order_key) AS shipment_volume\n",
        "FROM supply_chain.silver.car_orders_clean\n",
        "GROUP BY DATE_FORMAT(order_date, 'yyyy-MM')\n",
        "ORDER BY order_month;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "a0a095c8",
      "displayName": "Experience Quality Score",
      "queryLines": [
        "SELECT \n",
        "DATE_FORMAT(order_date, 'yyyy-MM') AS order_month,\n",
        "ROUND(AVG(rating / max_rating) * 100,2) AS experience_quality_score\n",
        "FROM supply_chain.silver.car_orders_clean\n",
        "GROUP BY DATE_FORMAT(order_date, 'yyyy-MM')\n",
        "ORDER BY order_month;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "487f9995",
      "displayName": "Late Delivery Impact on Ratings",
      "queryLines": [
        "SELECT \n",
        "CASE \n",
        "WHEN is_late_delivery = true THEN 'Late Delivery'\n",
        "ELSE 'On Time'\n",
        "END AS delivery_group,\n",
        "AVG(rating) AS avg_rating\n",
        "FROM supply_chain.silver.car_orders_clean\n",
        "GROUP BY delivery_group;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "f23e0dfd",
      "displayName": "Transport Mode Risk Score",
      "queryLines": [
        "SELECT \n",
        "transport_mode,\n",
        "ROUND(AVG(delay_days),2) AS risk_score\n",
        "FROM supply_chain.silver.car_orders_clean\n",
        "GROUP BY transport_mode\n",
        "ORDER BY risk_score DESC;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "d5bc7c0d",
      "displayName": "Total Order Count",
      "queryLines": [
        "SELECT COUNT(order_key) AS total_orders\n",
        "FROM supply_chain.silver.car_orders_clean;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "4aab5571",
      "displayName": "Count by Vehicle Brand",
      "queryLines": [
        "SELECT \n",
        "vehicle_brand,\n",
        "COUNT(order_key) AS order_count\n",
        "FROM supply_chain.silver.car_orders_clean\n",
        "GROUP BY vehicle_brand\n",
        "ORDER BY order_count DESC;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "399615af",
      "displayName": "Count by Country",
      "queryLines": [
        "SELECT \n",
        "country,\n",
        "COUNT(order_key) AS order_count\n",
        "FROM supply_chain.silver.car_orders_clean\n",
        "GROUP BY country\n",
        "ORDER BY order_count DESC;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "3e017ff9",
      "displayName": "Delay by Country",
      "queryLines": [
        "SELECT \n",
        "country,\n",
        "ROUND(AVG(delay_days),2) AS avg_delay\n",
        "FROM supply_chain.silver.car_orders_clean\n",
        "GROUP BY country\n",
        "ORDER BY avg_delay DESC;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "d66fe7bd",
      "displayName": "Yearly Delay Trend",
      "queryLines": [
        "SELECT \n",
        "YEAR(order_date) AS order_year,\n",
        "ROUND(AVG(delay_days),2) AS avg_delay\n",
        "FROM supply_chain.silver.car_orders_clean\n",
        "GROUP BY YEAR(order_date)\n",
        "ORDER BY order_year;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "9a37f77c",
      "displayName": "Monthly Delay Trend",
      "queryLines": [
        "SELECT \n",
        "DATE_FORMAT(order_date, 'yyyy-MM') AS order_month,\n",
        "ROUND(AVG(delay_days),2) AS avg_delay\n",
        "FROM supply_chain.silver.car_orders_clean\n",
        "GROUP BY DATE_FORMAT(order_date, 'yyyy-MM')\n",
        "ORDER BY order_month;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "551129c0",
      "displayName": "Delay Rate Calculation",
      "queryLines": [
        "SELECT \n",
        "ROUND(\n",
        "SUM(CASE WHEN is_late_delivery = true THEN 1 ELSE 0 END) * 100.0 / COUNT(*),\n",
        "2\n",
        ") AS delay_rate_percentage\n",
        "FROM supply_chain.silver.car_orders_clean;"
      ],
      "catalog": "supply_chain",
      "schema": "silver"
    },
    {
      "name": "95f59eee",
      "displayName": "Untitled dataset 2",
      "queryLines": [
        ""
      ]
    }
  ],
